# Discord browser listener target. You can set DISCORD_CHANNEL_URL directly,
# or set guild/channel IDs and let the app build the URL.
DISCORD_CHANNEL_URL=https://discord.com/channels/579151027169918986/885567780924043334
DISCORD_GUILD_IDS=579151027169918986
DISCORD_CHANNEL_IDS=885567780924043334

# Persistent browser profile. Log in once, then this profile reuses the
# Discord session on future runs.
BROWSER_PROFILE_DIR=data/discord-profile
DATABASE_PATH=data/messages.sqlite3
BROWSER_HEADLESS=false
POLL_INTERVAL_SECONDS=5
NOTIFY_RECENT_SECONDS=120
NO_MESSAGE_ALERT_SECONDS=10800
SUPERVISOR_RESTART_DELAY_SECONDS=30
ACTIVE_START_HOUR=9
ACTIVE_END_HOUR=21
ACTIVE_TIMEZONE=America/Toronto

# Backfill defaults to the last 90 days and stops once the oldest visible
# loaded message is older than the cutoff.
BACKFILL_DAYS=90
BACKFILL_SCROLLS=200
BACKFILL_SETTLE_SECONDS=1.0

# Slack incoming webhooks. SLACK_WEBHOOK_URL is ops/errors/health.
# SLACK_MATCHES_WEBHOOK_URL is where matched Discord messages go.
SLACK_WEBHOOK_URL=
SLACK_MATCHES_WEBHOOK_URL=

# Optional labels used in Slack context.
BRIDGE_NAME=discord-slack-listener

# Ignore Discord bot/webhook messages by default.
IGNORE_BOTS=true

# Basic starter filters. The richer criteria hook lives in
# discord_slack_listener/criteria.py.
MATCH_KEYWORDS=FedRAMP,CUI,20x,Nessus,Tenable,ConMon
MATCH_REGEX=

# LLM settings. Not used by the first-pass listener, but reserved for later
# criteria/classification work.
LLM_API_KEY=
AI_MODEL=
LLM_API_BASE=

# Logging.
LOG_LEVEL=INFO
